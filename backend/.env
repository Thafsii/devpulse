# DevPulse Backend — Environment Variables
# Fill in your values below. Never commit this file to version control.

# ── Supabase ──────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key — used by backend for server-side writes (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (AI processing layer) ──────────────────────────────
# If left empty, rule-based fallback is used instead (no OpenAI needed)
OPENAI_API_KEY=

# ── GitHub (personal access token) ────────────────────────────
# Raises rate limit from 60 → 5,000 req/hr (no scopes needed for public repos)
# Create one at: https://github.com/settings/tokens
GITHUB_PAT=

# ── Product Hunt (developer token) ────────────────────────────
# Register your app at: https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_TOKEN=

# ── Scheduler ─────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=2

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://*.netlify.app

# ── Debug ─────────────────────────────────────────────────────
DEBUG=false
