# DevPulse Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key is used by the backend for server-side writes (bypasses RLS).
# Keep this secret — never expose it in the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (AI processing layer) ──────────────────────────────
# Used by the hybrid processor to enhance scraped data.
# If left empty, the rule-based fallback is used instead.
OPENAI_API_KEY=

# ── GitHub (personal access token) ────────────────────────────
# Increases rate limit from 60 to 5,000 req/hr.
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_PAT=

# ── Product Hunt (developer token) ────────────────────────────
# Register your app at: https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_TOKEN=

# ── Scheduler ─────────────────────────────────────────────────
# How often (in hours) to run scrapers. Minimum recommended: 1
SCRAPE_INTERVAL_HOURS=2

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Netlify URL here when deploying, e.g.:
#   CORS_ORIGINS=http://localhost:3000,https://your-app.netlify.app
CORS_ORIGINS=http://localhost:3000,https://*.netlify.app

# ── Debug ─────────────────────────────────────────────────────
DEBUG=false
